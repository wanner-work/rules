{
  "name": "@wanner.work/oxfmt-rules",
  "version": "1.0.0-rc.0",
  "description": "oxfmt rules to write consistent code.",
  "keywords": [
    "formatting",
    "oxfmt"
  ],
  "homepage": "https://rules.wanner.work",
  "bugs": {
    "url": "https://github.com/wanner-work/rules/issues"
  },
  "license": "MIT",
  "author": "Jonas Wanner <jonas@wanner.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wanner-work/rules.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build",
    "format": "oxfmt --write .",
    "lint": "oxlint",
    "check": "node tests/run-oxlint-tests.mjs",
    "release": "bumpp --tag='@wanner.work/oxfmt-rules-v'"
  },
  "dependencies": {
    "defu": "6.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.3",
    "typescript": "7.0.1-rc"
  },
  "peerDependencies": {
    "oxfmt": "^0.52.0"
  }
}
