{
  "name": "@wanner.work/oxlint-rules",
  "version": "1.0.0",
  "description": "oxlint rules to write consistent code.",
  "homepage": "https://wanner.work/rules",
  "license": "MIT",
  "author": "Jonas Wanner <jonas@wanner.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wanner-work/rules.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build",
    "format": "oxfmt --write .",
    "lint": "oxlint",
    "check": "node tests/run-oxlint-tests.mjs"
  },
  "dependencies": {
    "defu": "6.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.0"
  },
  "inlinedDependencies": {
    "oxlint": "1.69.0"
  }
}
